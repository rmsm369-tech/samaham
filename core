import torch
import torch.nn as nn

class AwarenessDecayNetwork(nn.Module):
    def __init__(self, input_size=2, hidden_size=2, output_size=1):
        super().__init__()
        
        # The Habit (Standard neural pathway)
        self.primary_network = nn.Sequential(
            nn.Linear(input_size, hidden_size),
            nn.ReLU(),
            nn.Linear(hidden_size, output_size)
        )
        
        # The Meta-Observer (Evaluates if it should act)
        self.meta_observer = nn.Sequential(
            nn.Linear(input_size, hidden_size),
            nn.Sigmoid() 
        )
        
        # The mathematical rate of dissolution
        self.gamma = 0.05 
        self.threshold = nn.Parameter(torch.tensor(0.3)) # Learnable threshold for action inhibition

    def forward(self, x):
        urge_to_act = self.meta_observer(x).mean()
        
        threshold = self.threshold
        if urge_to_act < threshold:
            # NON-ACTION: The network chooses silence. 
            return torch.zeros(1, self.primary_network[-1].out_features), urge_to_act, True 
            
        # ACTION Phase
        action = self.primary_network(x)
        return action, urge_to_act, False

def train_step(model, optimizer, x, target):
    optimizer.zero_grad() 
    action, urge_to_act, veto_triggered = model(x)
    
    if veto_triggered:
        loss = urge_to_act 
        # Active Inhibitory Unlearning
        with torch.no_grad():
            for param in model.primary_network.parameters():
                param -= model.gamma * param.abs() 
        status = "Veto Triggered   -> Silence. Weights decayed."
    else:
        criterion = nn.MSELoss()
        loss = criterion(action, target)
        status = "Action Permitted -> Standard forward pass."
        
    loss.backward()
    optimizer.step()
    return status

def test_loop():
    torch.manual_seed(42) # For reproducible results
    model = AwarenessDecayNetwork()
    optimizer = torch.optim.SGD(model.parameters(), lr=0.01)
    
    x = torch.tensor([1.0, 0.3]) # Input that may trigger action ambigously
    target = torch.tensor([1.0])
    
    print("\n--- INITIAL PRIMARY WEIGHTS ---")
    print(model.primary_network[0].weight.data)
    
    print("\n--- RUNNING 100 OBSERVATION CYCLES ---")
    for i in range(1, 101):
        status = train_step(model, optimizer, x, target)
        if i % 20 == 0: # Print every 20 steps
            print(f"Cycle {i:03d}: {status}")
            
    print("\n--- FINAL PRIMARY WEIGHTS (Notice the dissolution) ---")
    print(model.primary_network[0].weight.data)
    print("\n")

if __name__ == "__main__":
    test_loop()